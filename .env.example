# ==============================================================
# Nagrik — Root Environment Variables TEMPLATE
# ==============================================================
# This file IS committed to version control — it contains NO secrets.
# It serves as documentation for every variable the app needs.
#
# HOW TO USE:
#   cp .env.example .env
#   Then fill in your real values in .env
# ==============================================================


# ── SERVER (Backend) ──────────────────────────────────────────

PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/nagrik
JWT_SECRET=your_super_secret_jwt_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CORS_ORIGIN=http://localhost:5173


# ── FRONTEND (Vite — must be prefixed with VITE_) ─────────────

VITE_API_URL=http://localhost:5000/api
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_GEMINI_API_KEY=
