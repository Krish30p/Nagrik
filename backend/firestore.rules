rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to check if user owns the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Helper to check if user has admin role
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.role == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.level >= 5 ||
         request.auth.token.email.matches('.*@nagrik\\.gov\\.in'));
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Issues Collection rules
    match /issues/{issueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.createdBy) || isAdmin();
    }

    // Threads Collection rules
    match /threads/{threadId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // allow confirmations updates
    }

    // Departments Collection rules
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Complaints Collection rules
    match /complaints/{complaintId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Escalations Collection rules
    match /escalations/{escId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // Only agents/admins write escalations
    }

    // Notifications Collection rules
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId); // allow marking read
      allow create, delete: if isSignedIn(); // allow system agents/users to create
    }
  }
}
